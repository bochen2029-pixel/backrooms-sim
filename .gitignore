# Build output
/build/
/build-*/
/out/
**/vcpkg_installed/

# Run artifacts and telemetry (ARCHITECTURE.md §10)
/runs/*
!/runs/.gitkeep

# Autopilot supervisor sentinels (scripts/autoloop.ps1 writes DONE / STALLED here)
/.brstate/

# vcpkg (external, bootstrapped by scripts/bootstrap; never vendored)
/extern/vcpkg/

# IDE / tooling
.vs/
.vscode/
*.user
CMakeUserPresets.json
compile_commands.json

# Redundant delivery artifacts (the starter zip + its extracted duplicate of
# this very repo). The repo root is the source of truth.
/files/
*.zip

# OS
Thumbs.db
desktop.ini

# M16 runtime config (written next to the exe / cwd)
backrooms.cfg

# M17 packaging output
dist/
build-release/

# M17 procedural app icon (generated at build time by icongen)
app/backrooms.ico
