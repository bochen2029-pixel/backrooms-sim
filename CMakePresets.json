{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 28, "patch": 0 },
  "configurePresets": [
    {
      "name": "ninja-vcpkg",
      "displayName": "Ninja + vcpkg (MSVC, static)",
      "description": "Single-config Ninja build using the vcpkg toolchain (VCPKG_ROOT must be set).",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static",
        "VCPKG_HOST_TRIPLET": "x64-windows-static"
      }
    }
  ],
  "buildPresets": [
    { "name": "ninja-vcpkg", "configurePreset": "ninja-vcpkg" }
  ],
  "testPresets": [
    {
      "name": "ninja-vcpkg",
      "configurePreset": "ninja-vcpkg",
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": false }
    }
  ]
}
