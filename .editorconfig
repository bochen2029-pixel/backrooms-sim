root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{cpp,h,hpp,cc,cxx}]
indent_size = 4

[*.{cmake,txt}]
indent_size = 2

[CMakeLists.txt]
indent_size = 2

[*.{json,yml,yaml}]
indent_size = 2

[*.ps1]
end_of_line = crlf
indent_size = 4

[*.md]
trim_trailing_whitespace = false
